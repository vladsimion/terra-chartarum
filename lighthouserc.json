{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/essays/index.html",
        "http://localhost/atlas/index.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "comment": "Quality gates that every key route must clear.",
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.9 }],
            "categories:seo": ["error", { "minScore": 0.9 }]
          }
        },
        {
          "comment": "Content routes are light; hold them to the full >=0.9 budget.",
          "matchingUrlPattern": "(localhost/index|essays/index)\\.html$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.9 }]
          }
        },
        {
          "comment": "The atlas hosts an intentional heavy interactive WebGL map (MapLibre, ~800 KiB) above the fold, so it carries a realistic, still-regression-guarding budget rather than the full 0.9.",
          "matchingUrlPattern": "atlas/index\\.html$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.8 }]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
