---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// Self-hosted fonts (KAN-53 / ATLAS-602): bundled same-origin woff2 via
// @fontsource, replacing the render-blocking Google Fonts CDN. Variable faces
// cover every weight in one file each; italic is only pulled for the body
// families that use it. All are font-display: swap and unicode-range subset,
// so browsers fetch only the latin glyphs actually rendered.
import '@fontsource-variable/cinzel/wght.css';
import '@fontsource-variable/crimson-pro/wght.css';
import '@fontsource-variable/crimson-pro/wght-italic.css';
import '@fontsource-variable/eb-garamond/wght.css';
import '@fontsource-variable/eb-garamond/wght-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Hide the shared chrome (used by the full-bleed essay host route). */
  bare?: boolean;
  ogImage?: string;
}

const {
  title,
  description = 'An interactive historical atlas — a gallery of cartographic visual essays.',
  bare = false,
  ogImage = '/og/default.png',
} = Astro.props;

const siteName = 'Terra Chartarum';
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0806" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Terra Chartarum — Essays"
      href="/rss.xml"
    />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Fonts are now self-hosted (KAN-53) — bundled via @fontsource in the
         layout frontmatter, so there is no external font CDN request. -->

    <ViewTransitions />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    {!bare && <Header />}
    <main id="main-content" tabindex="-1" class="flex-1">
      <slot />
    </main>
    {!bare && <Footer />}

    <script>
      // A11y (KAN-52): Astro's view transitions swap the DOM without moving
      // focus, which strands keyboard and screen-reader users on a now-removed
      // element. After each swap, send focus to the top of the new page's main
      // content (which is tabindex="-1" and shows no focus box) so the next Tab
      // continues from a sensible place. Registered once; persists across swaps.
      document.addEventListener('astro:after-swap', () => {
        document.getElementById('main-content')?.focus({ preventScroll: true });
      });
    </script>
  </body>
</html>
