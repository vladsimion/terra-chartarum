---
import PortalLayout from '../../layouts/PortalLayout.astro';
import { getCartographers, mapsByCartographer } from '../../lib/cartographers';
import { formatYear } from '../../lib/registry';

const cartographers = getCartographers();
const lifespan = (born?: number, died?: number) =>
  born || died
    ? `${born ? formatYear(born) : '?'} – ${died ? formatYear(died) : '?'}`
    : '';
---

<PortalLayout
  title="Cartographers"
  description="The mapmakers behind the corpus — their lives, places, and the maps they left."
>
  <section class="shell people">
    <header class="people-head">
      <p class="eyebrow">The makers</p>
      <h1>Cartographers</h1>
      <p class="lede">
        {cartographers.length} mapmakers whose work runs through the essays —
        with the maps each of them left in the collection.
      </p>
    </header>

    <ul class="grid">
      {cartographers.map((c) => {
        const maps = mapsByCartographer(c.id);
        return (
          <li class="pcard">
            <a href={`/cartographers/${c.id}/`}>
              <h2>{c.name}</h2>
              {lifespan(c.born, c.died) && <p class="dates">{lifespan(c.born, c.died)}</p>}
              {c.places.length > 0 && <p class="places">{c.places.join(' · ')}</p>}
              <p class="bio">{c.bio}</p>
              <p class="mapcount">{maps.length} {maps.length === 1 ? 'map' : 'maps'} in the collection</p>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</PortalLayout>

<style>
  .people { padding-block: clamp(2.5rem, 6vw, 4rem); }
  .people-head { max-width: var(--prose-max); margin-bottom: 2rem; }
  .people-head h1 { font-size: var(--step-4); margin: 0.3rem 0 0.75rem; }
  .lede { color: var(--ink-muted); font-size: var(--step-1); margin: 0; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pcard {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    transition:
      transform var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  .pcard:hover { transform: translateY(-4px); border-color: var(--gold); }
  .pcard a { display: block; color: inherit; padding: 1.35rem 1.4rem 1.5rem; height: 100%; }
  .pcard h2 { font-size: var(--step-2); margin: 0 0 0.3rem; color: var(--ink); }
  .dates {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--gold);
    margin: 0 0 0.15rem;
  }
  .places {
    font-style: italic;
    color: var(--ink-muted);
    margin: 0 0 0.75rem;
    font-size: var(--step-0);
  }
  .bio { color: var(--ink-muted); font-size: var(--step-0); margin: 0 0 1rem; }
  .mapcount {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink);
    margin: 0;
  }
</style>
