---
import PortalLayout from '../../layouts/PortalLayout.astro';
import CatalogueCard from '../../components/CatalogueCard.astro';
import { getCorpus, centuryLabel } from '../../lib/corpus';
import { getEssays } from '../../lib/registry';

const maps = getCorpus();
const essays = await getEssays();
const essayMeta = Object.fromEntries(
  essays.map((e) => [e.slug, { title: e.data.title, accent: e.data.accent ?? '#d4b87a' }]),
);

// Facets derived from the corpus itself, so a new field on a record surfaces
// automatically (KAN-67). Regions/tags/cartographers may be sparse until the
// rich catalogue metadata is populated.
const uniqSorted = (xs: string[]) => Array.from(new Set(xs.filter(Boolean))).sort();
const regions = uniqSorted(maps.map((m) => m.region));
// Centuries ordered chronologically (by the underlying year), not alphabetically.
const centuries = Array.from(
  new Map(
    [...maps]
      .sort((a, b) => a.year - b.year)
      .map((m) => [centuryLabel(m.year), true]),
  ).keys(),
);
const cartographers = uniqSorted(maps.map((m) => m.cartographer ?? ''));
const tags = uniqSorted(maps.flatMap((m) => m.tags));
const essayOptions = essays
  .filter((e) => maps.some((m) => m.essaySlug === e.slug))
  .map((e) => ({ slug: e.slug, title: e.data.title }));
---

<PortalLayout
  title="Collection"
  description="The full catalogue of historical maps discussed across the essays — filterable by century, region, cartographer, and lens."
>
  <section class="shell catalogue">
    <header class="catalogue-head">
      <p class="eyebrow">The collection</p>
      <h1>Catalogue of maps</h1>
      <p class="lede">
        {maps.length} historical maps across every essay. Filter by century,
        region, cartographer, or tag — or search by title.
      </p>
    </header>

    <div class="controls" role="search">
      <input
        id="q"
        type="search"
        placeholder="Search maps…"
        aria-label="Search maps by title, region, or cartographer"
        autocomplete="off"
      />
      <div class="facet">
        <label for="century">Century</label>
        <select id="century" data-facet="centuries">
          <option value="">All centuries</option>
          {centuries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </div>
      <div class="facet">
        <label for="region">Region</label>
        <select id="region" data-facet="regions">
          <option value="">All regions</option>
          {regions.map((r) => <option value={r}>{r}</option>)}
        </select>
      </div>
      <div class="facet">
        <label for="essay">Essay</label>
        <select id="essay" data-facet="essays">
          <option value="">All essays</option>
          {essayOptions.map((e) => <option value={e.slug}>{e.title}</option>)}
        </select>
      </div>
      {cartographers.length > 0 && (
        <div class="facet">
          <label for="cartographer">Cartographer</label>
          <select id="cartographer" data-facet="cartographers">
            <option value="">All cartographers</option>
            {cartographers.map((c) => <option value={c}>{c}</option>)}
          </select>
        </div>
      )}
      {tags.length > 0 && (
        <div class="facet">
          <label for="tag">Tag</label>
          <select id="tag" data-facet="tags">
            <option value="">All tags</option>
            {tags.map((t) => <option value={t}>{t}</option>)}
          </select>
        </div>
      )}
      <button id="reset" type="button">Reset</button>
    </div>

    <p id="count" class="count" aria-live="polite"></p>

    <div class="grid" id="grid">
      {maps.map((m) => (
        <CatalogueCard
          map={m}
          essayTitle={essayMeta[m.essaySlug]?.title ?? m.essaySlug}
          accent={essayMeta[m.essaySlug]?.accent}
        />
      ))}
    </div>
    <p id="empty" class="empty" hidden>No maps match those filters.</p>
  </section>
</PortalLayout>

<script>
  // Client-side faceted filtering (KAN-67), mirroring the essay gallery.
  function initCatalogue() {
    const grid = document.getElementById('grid');
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.mcard'));
    const q = document.getElementById('q') as HTMLInputElement;
    const selects = Array.from(
      document.querySelectorAll<HTMLSelectElement>('select[data-facet]'),
    );
    const reset = document.getElementById('reset');
    const count = document.getElementById('count');
    const empty = document.getElementById('empty');

    function apply() {
      const term = (q?.value ?? '').trim().toLowerCase();
      let shown = 0;
      for (const card of cards) {
        let ok = true;
        for (const sel of selects) {
          if (!sel.value) continue;
          const field = sel.dataset.facet!;
          const values = (card.dataset[field] ?? '').split('|');
          if (!values.includes(sel.value)) ok = false;
        }
        if (ok && term) ok = (card.dataset.title ?? '').includes(term);
        card.hidden = !ok;
        if (ok) shown++;
      }
      if (count) count.textContent = `${shown} of ${cards.length} maps`;
      if (empty) empty.hidden = shown !== 0;
    }

    q?.addEventListener('input', apply);
    selects.forEach((s) => s.addEventListener('change', apply));
    reset?.addEventListener('click', () => {
      if (q) q.value = '';
      selects.forEach((s) => (s.value = ''));
      apply();
    });
    apply();
  }

  initCatalogue();
  document.addEventListener('astro:page-load', initCatalogue);
</script>

<style>
  .catalogue { padding-block: clamp(2.5rem, 6vw, 4rem); }
  .catalogue-head { max-width: var(--prose-max); margin-bottom: 2rem; }
  .catalogue-head h1 { font-size: var(--step-4); margin: 0.3rem 0 0.75rem; }
  .lede { color: var(--ink-muted); font-size: var(--step-1); margin: 0; }

  .controls {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    margin-bottom: 1rem;
  }
  .controls input[type='search'] {
    flex: 1 1 220px;
    min-width: 180px;
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    color: var(--ink);
    padding: 0.6rem 0.8rem;
    font-family: var(--font-body);
    font-size: var(--step-0);
  }
  .facet { display: flex; flex-direction: column; gap: 0.3rem; }
  .facet label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .controls select,
  .controls button {
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    color: var(--ink);
    padding: 0.55rem 0.7rem;
    font-family: var(--font-body);
    font-size: var(--step-0);
    cursor: pointer;
  }
  .controls button:hover { border-color: var(--gold); color: var(--gold); }
  .count {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-muted);
    margin: 0 0 1.5rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .empty { color: var(--ink-muted); font-style: italic; padding: 2rem 0; }
</style>
