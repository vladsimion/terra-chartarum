---
/**
 * AtlasMap (ATLAS-502 / ATLAS-EG3)
 *
 * Cross-essay map view: MapLibre GL base map with a pin per corpus map, popups
 * deep-linking to the source essay, a chronological time-slider, and faceted
 * search. Registered GeoLayers (ATLAS-EG2) render as live vector overlays via the
 * MapLibre pipeline (ATLAS-EG3): GeoJSON sources load now; the PMTiles protocol is
 * registered so a `.pmtiles` layer goes live the moment its asset is present. The
 * time-slider filters both corpus pins and geo layers by temporal extent. Degrades
 * to a grouped list where WebGL is unavailable.
 */
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import 'maplibre-gl/dist/maplibre-gl.css';
import { getCorpusCore, corpusYearRange } from '../../lib/corpus';
import { getGeoLayers } from '../../lib/geo';
import { coveragePolygons } from '../../lib/coverage';
import { getToponyms, toponymNames } from '../../lib/toponyms';
import { getEssays, formatYear } from '../../lib/registry';

// Only the atlas-critical projection ships to the client — rich catalogue
// metadata (provenance, bibliography, imagery) stays server-side (KAN-66).
const corpus = getCorpusCore();
const layers = getGeoLayers();
const essays = await getEssays();
const [minYear, maxYear] = corpusYearRange();

// Depicted-extent footprints (KAN-74): each map's coverage ring plus its title,
// in corpus (chronological) order, for the atlas "depicted within" filter.
const corpusTitle = new Map(corpus.map((m) => [m.id, m.title] as const));
const coverage = coveragePolygons()
  .filter((c) => corpusTitle.has(c.mapId))
  .map((c) => ({ id: c.mapId, title: corpusTitle.get(c.mapId)!, ring: c.ring }))
  .sort((a, b) => corpus.findIndex((m) => m.id === a.id) - corpus.findIndex((m) => m.id === b.id));

// A layer is toggleable only when its asset is actually on disk under /public.
const publicDir = join(process.cwd(), 'public');
const layerMeta = layers.map((l) => ({
  ...l,
  available: existsSync(join(publicDir, l.url.replace(/^\//, ''))),
}));

const essayMeta = Object.fromEntries(
  essays.map((e) => [e.slug, { title: e.data.title, accent: e.data.accent ?? '#d4b87a' }]),
);

// Toponym concordance (KAN-75): a separate, toggleable pin set of places carrying
// the ancient / medieval / variant names by which the corpus calls them, with the
// essays and maps that reference each — resolved here so the popup is self-contained.
const toponyms = getToponyms().map((t) => ({
  id: t.id,
  modern: t.modern,
  names: toponymNames(t),
  historical: toponymNames(t).slice(1),
  coords: t.coords,
  pleiadesId: t.pleiadesId ?? null,
  essays: t.essaySlugs.map((s) => ({ slug: s, title: essayMeta[s]?.title ?? s })),
  maps: t.mapIds
    .filter((id) => corpusTitle.has(id))
    .map((id) => ({ id, title: corpusTitle.get(id)! })),
}));

const payload = {
  corpus: corpus.map((m) => ({
    ...m,
    accent: essayMeta[m.essaySlug]?.accent ?? '#d4b87a',
    essayTitle: essayMeta[m.essaySlug]?.title ?? m.essaySlug,
    yearLabel: formatYear(m.year),
  })),
  layers: layerMeta.map((l) => ({
    id: l.id,
    url: l.url,
    format: l.format,
    geometry: l.geometry,
    color: l.color,
    yearFrom: l.yearFrom,
    yearTo: l.yearTo,
    sourceLayer: l.sourceLayer ?? null,
    perFeatureTime: l.perFeatureTime,
    graduate: l.graduate ?? null,
    dash: l.dash ?? null,
    available: l.available,
    defaultOn: l.defaultOn && l.available,
  })),
  coverage,
  toponyms,
  minYear,
  maxYear,
};
---

<section class="atlasmap" data-atlasmap>
  <div class="controls">
    <input
      type="search"
      class="am-search"
      placeholder="Search maps, regions, essays…"
      aria-label="Search the corpus"
    />
    <select class="am-essay" aria-label="Filter by essay">
      <option value="">All essays</option>
      {essays.map((e) => <option value={e.slug}>{e.data.title}</option>)}
    </select>
    {
      coverage.length > 0 && (
        <select class="am-covers" aria-label="Show only maps depicted within another map's extent">
          <option value="">Depicted anywhere</option>
          {coverage.map((c) => (
            <option value={c.id}>Within {c.title}</option>
          ))}
        </select>
      )
    }
    <div class="am-time">
      <label for="am-year">Reveal through</label>
      <input
        id="am-year"
        class="am-year"
        type="range"
        min={minYear}
        max={maxYear}
        value={maxYear}
        step="1"
      />
      <output class="am-year-out" for="am-year">{formatYear(maxYear)}</output>
    </div>
    {
      toponyms.length > 0 && (
        <label class="am-topo-toggle">
          <input type="checkbox" class="am-topo-check" />
          <span>Ancient &amp; medieval place-names</span>
        </label>
      )
    }
  </div>

  <div class="am-stage">
    <div class="am-map" role="application" aria-label="Map of the essay corpus"></div>
    <noscript>
      <p class="am-fallback-note">
        The interactive map needs JavaScript. The full corpus is listed below.
      </p>
    </noscript>
  </div>

  {
    layerMeta.length > 0 && (
      <fieldset class="am-layers">
        <legend>Historical GIS layers</legend>
        <p class="am-layers-note">
          Regime A (serverless) vector layers. Available assets render live and obey the
          time-slider; layers awaiting a sourced dataset are marked pending.
        </p>
        {layerMeta.map((l) => (
          <label
            class:list={['am-layer', { 'is-pending': !l.available }]}
            title={`${l.description} — ${l.source} (${l.license})`}
          >
            <input
              type="checkbox"
              data-layer={l.id}
              checked={l.defaultOn && l.available}
              disabled={!l.available}
            />
            <span>{l.title}</span>
            <span class="am-layer-meta">
              {l.format} · {formatYear(l.yearFrom)}–{formatYear(l.yearTo)}
              {!l.available && ' · pending'}
            </span>
          </label>
        ))}
      </fieldset>
    )
  }

  <!-- Progressive-enhancement fallback: full corpus as a grouped list. -->
  <ol class="am-list">
    {
      corpus.map((m) => (
        <li>
          <a href={`/essays/${m.essaySlug}/`}>
            <span class="am-list-year">{formatYear(m.year)}</span>
            <span class="am-list-title">{m.title}</span>
            <span class="am-list-region">{m.region}</span>
          </a>
        </li>
      ))
    }
  </ol>

  <script type="application/json" data-atlasmap-data set:html={JSON.stringify(payload)} />
</section>

<script>
  // Type-only imports are erased at build, so MapLibre (~785K) and pmtiles are
  // pulled in lazily via dynamic import() below — only once the map actually
  // initializes with WebGL present. Readers without WebGL never download them.
  import type {
    Map as MLMap,
    Marker as MLMarker,
    AddLayerObject,
    FilterSpecification,
  } from 'maplibre-gl';
  import {
    circleRadiusExpression,
    withTemporal,
    dashSubLayers,
    type GraduateHint,
    type DashHint,
  } from '../../lib/geo-style';

  // Register the pmtiles:// protocol at most once across page-load re-inits.
  let protocolRegistered = false;

  type Pt = {
    id: string;
    title: string;
    year: number;
    yearLabel: string;
    essaySlug: string;
    essayTitle: string;
    region: string;
    coords: [number, number];
    accent: string;
    blurb?: string;
  };

  type LayerMeta = {
    id: string;
    url: string;
    format: string;
    geometry: 'line' | 'fill' | 'circle';
    color: string;
    yearFrom: number;
    yearTo: number;
    sourceLayer: string | null;
    perFeatureTime: boolean;
    graduate: GraduateHint | null;
    dash: DashHint | null;
    available: boolean;
    defaultOn: boolean;
  };

  type Coverage = { id: string; title: string; ring: [number, number][] };

  type Toponym = {
    id: string;
    modern: string;
    names: string[];
    historical: string[];
    coords: [number, number];
    pleiadesId: string | null;
    essays: { slug: string; title: string }[];
    maps: { id: string; title: string }[];
  };

  function hasWebGL(): boolean {
    try {
      const c = document.createElement('canvas');
      return !!(c.getContext('webgl2') || c.getContext('webgl'));
    } catch {
      return false;
    }
  }

  async function initAtlasMap(root: HTMLElement) {
    const dataEl = root.querySelector<HTMLElement>('[data-atlasmap-data]');
    const mapEl = root.querySelector<HTMLElement>('.am-map');
    if (!dataEl || !mapEl) return;
    const parsed = JSON.parse(dataEl.textContent || '{}') as {
      corpus: Pt[];
      layers?: LayerMeta[];
      coverage?: Coverage[];
      toponyms?: Toponym[];
    };
    const corpus = parsed.corpus ?? [];
    const geoLayers = parsed.layers ?? [];
    const coverage = parsed.coverage ?? [];
    const toponyms = parsed.toponyms ?? [];

    // Ray-casting point-in-ring, inlined (no turf.js) for the footprint filter.
    const pointInRing = (x: number, y: number, ring: [number, number][]) => {
      let inside = false;
      for (let i = 0, j = ring.length - 1; i < ring.length; j = i++) {
        const [xi, yi] = ring[i];
        const [xj, yj] = ring[j];
        if (yi > y !== yj > y && x < ((xj - xi) * (y - yi)) / (yj - yi) + xi) {
          inside = !inside;
        }
      }
      return inside;
    };

    const search = root.querySelector<HTMLInputElement>('.am-search')!;
    const essaySel = root.querySelector<HTMLSelectElement>('.am-essay')!;
    const coversSel = root.querySelector<HTMLSelectElement>('.am-covers');
    const yearIn = root.querySelector<HTMLInputElement>('.am-year')!;
    const yearOut = root.querySelector<HTMLOutputElement>('.am-year-out')!;
    const topoCheck = root.querySelector<HTMLInputElement>('.am-topo-check');
    const list = root.querySelector<HTMLElement>('.am-list')!;
    const layerToggles = Array.from(
      root.querySelectorAll<HTMLInputElement>('.am-layer input[data-layer]'),
    );

    const fmt = (y: number) => (y < 0 ? `${Math.abs(y)} BC` : `AD ${y}`);

    // Where WebGL is missing, keep the list and drop the empty map frame.
    if (!hasWebGL()) {
      mapEl.remove();
      root
        .querySelector('.am-stage')
        ?.insertAdjacentHTML(
          'beforeend',
          '<p class="am-fallback-note">WebGL is unavailable — showing the corpus as a list.</p>',
        );
      list.classList.add('is-fallback');
      // Geo overlays need the GL map; disable their toggles in the fallback.
      layerToggles.forEach((cb) => {
        cb.checked = false;
        cb.disabled = true;
      });
    }

    const markers: { pt: Pt; marker?: MLMarker; li: HTMLElement }[] = [];
    const listItems = Array.from(list.querySelectorAll('li'));
    corpus.forEach((pt, i) => markers.push({ pt, li: listItems[i] }));

    // A dedicated concordance pin set (KAN-75), kept entirely separate from both
    // the corpus pins and the GeoLayer pipeline (addGeoLayer has no point branch).
    const topoMarkers: { topo: Toponym; marker: MLMarker }[] = [];

    let map: MLMap | null = null;
    let styleReady = false;
    const activeLayers = new Set<string>();
    const layerId = (id: string) => `geolyr-${id}`;
    const sourceId = (id: string) => `geosrc-${id}`;

    // One GeoLayer can expand into several MapLibre layers (a dashed-by-field line
    // splits into a filtered sub-layer per value). We track the created ids plus
    // each sub-layer's own base filter so the temporal reveal can AND onto it.
    type Part = { id: string; baseFilter: unknown | null };
    const parts = new Map<string, Part[]>();

    // Build the MapLibre render layer(s) for a GeoLayer from its geometry + hints.
    const buildParts = (
      l: LayerMeta,
      src: string,
    ): { layer: Record<string, unknown>; baseFilter: unknown | null }[] => {
      const lyr = layerId(l.id);
      const withSrcLayer = (o: Record<string, unknown>) => {
        if (l.format === 'pmtiles' && l.sourceLayer) o['source-layer'] = l.sourceLayer;
        return o;
      };
      if (l.geometry === 'fill') {
        return [
          {
            layer: withSrcLayer({
              id: lyr,
              type: 'fill',
              source: src,
              paint: { 'fill-color': l.color, 'fill-opacity': 0.22, 'fill-outline-color': l.color },
            }),
            baseFilter: null,
          },
        ];
      }
      if (l.geometry === 'circle') {
        // Graduated point symbols (ports): radius by categorical field, else flat.
        const radius = l.graduate ? circleRadiusExpression(l.graduate) : 5;
        return [
          {
            layer: withSrcLayer({
              id: lyr,
              type: 'circle',
              source: src,
              paint: {
                'circle-radius': radius,
                'circle-color': l.color,
                'circle-opacity': 0.85,
                'circle-stroke-width': 1,
                'circle-stroke-color': '#0b0b0c',
              },
            }),
            baseFilter: null,
          },
        ];
      }
      // Line — dashed by a categorical field means one filtered sub-layer per value
      // (line-dasharray is not a data-driven paint property in MapLibre).
      if (l.dash) {
        return dashSubLayers(l.dash).map((s) => {
          const paint: Record<string, unknown> = {
            'line-color': l.color,
            'line-width': 1.2,
            'line-opacity': 0.85,
          };
          if (s.dashArray.length) paint['line-dasharray'] = s.dashArray;
          return {
            layer: withSrcLayer({
              id: `${lyr}--${s.value}`,
              type: 'line',
              source: src,
              filter: s.filter,
              paint,
            }),
            baseFilter: s.filter,
          };
        });
      }
      return [
        {
          layer: withSrcLayer({
            id: lyr,
            type: 'line',
            source: src,
            paint: { 'line-color': l.color, 'line-width': 1.2, 'line-opacity': 0.85 },
          }),
          baseFilter: null,
        },
      ];
    };

    // Attach a GeoLayer's source + render layer(s) to the map. GeoJSON loads
    // directly; PMTiles goes through the registered pmtiles:// protocol; FlatGeobuf
    // is fetched and deserialized to a GeoJSON source via a lazily-loaded decoder
    // (VMN-2 blocker B1) — the decoder chunk only ships when an FGB layer is toggled.
    const addGeoLayer = async (l: LayerMeta) => {
      if (!map || !styleReady || map.getSource(sourceId(l.id))) return;
      const src = sourceId(l.id);
      if (l.format === 'geojson') {
        map.addSource(src, { type: 'geojson', data: l.url });
      } else if (l.format === 'pmtiles') {
        map.addSource(src, { type: 'vector', url: `pmtiles://${location.origin}${l.url}` });
      } else if (l.format === 'flatgeobuf') {
        try {
          const [{ geojson }, resp] = await Promise.all([import('flatgeobuf'), fetch(l.url)]);
          if (!map || !resp.ok || map.getSource(src)) return;
          const buf = new Uint8Array(await resp.arrayBuffer());
          // deserialize streams features as an async generator; collect into a
          // GeoJSON source MapLibre can consume.
          const features: GeoJSON.Feature[] = [];
          for await (const f of geojson.deserialize(buf)) {
            features.push(f as unknown as GeoJSON.Feature);
          }
          if (!map || map.getSource(src)) return;
          map.addSource(src, { type: 'geojson', data: { type: 'FeatureCollection', features } });
        } catch {
          return; // asset missing or malformed — leave the layer pending
        }
      } else {
        return; // cog needs a dedicated raster loader
      }
      if (!map) return;
      const built = buildParts(l, src);
      for (const b of built) map.addLayer(b.layer as unknown as AddLayerObject);
      parts.set(
        l.id,
        built.map((b) => ({ id: b.layer.id as string, baseFilter: b.baseFilter })),
      );
      syncLayerTime(Number(yearIn.value));
    };

    const removeGeoLayer = (id: string) => {
      if (!map) return;
      for (const p of parts.get(id) ?? []) {
        if (map.getLayer(p.id)) map.removeLayer(p.id);
      }
      if (map.getSource(sourceId(id))) map.removeSource(sourceId(id));
      parts.delete(id);
    };

    // Timeline sync. The layer envelope (registry yearFrom/yearTo) still gates
    // whole-layer visibility; on top, a per-feature layer (VMN phased model, blocker
    // B2) filters individual features by their inclusive valid_from/valid_to.
    const syncLayerTime = (cutoff: number) => {
      if (!map || !styleReady) return;
      for (const l of geoLayers) {
        const ps = parts.get(l.id);
        if (!activeLayers.has(l.id) || !ps) continue;
        const envelopeVisible = l.yearFrom <= cutoff;
        for (const p of ps) {
          if (!map.getLayer(p.id)) continue;
          map.setLayoutProperty(p.id, 'visibility', envelopeVisible ? 'visible' : 'none');
          if (l.perFeatureTime) {
            map.setFilter(p.id, withTemporal(p.baseFilter, cutoff) as FilterSpecification);
          }
        }
      }
    };

    if (mapEl.isConnected) {
      // Pull the heavy GL + tiling libs only now, when we're really rendering.
      const [{ default: maplibregl }, { Protocol }] = await Promise.all([
        import('maplibre-gl'),
        import('pmtiles'),
      ]);
      if (!protocolRegistered) {
        maplibregl.addProtocol('pmtiles', new Protocol().tile);
        protocolRegistered = true;
      }

      map = new maplibregl.Map({
        container: mapEl,
        style: 'https://demotiles.maplibre.org/style.json',
        center: [12, 41],
        zoom: 2.4,
        attributionControl: { compact: true },
      });
      map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

      for (const entry of markers) {
        const { pt } = entry;
        const el = document.createElement('button');
        el.className = 'am-pin';
        el.style.setProperty('--accent', pt.accent);
        el.setAttribute('aria-label', `${pt.title} (${pt.yearLabel})`);
        const popup = new maplibregl.Popup({ offset: 14, closeButton: false }).setHTML(
          `<div class="am-pop"><span class="am-pop-year">${pt.yearLabel}</span>` +
            `<strong class="am-pop-title">${pt.title}</strong>` +
            (pt.blurb ? `<span class="am-pop-blurb">${pt.blurb}</span>` : '') +
            `<a class="am-pop-link" href="/essays/${pt.essaySlug}/">${pt.essayTitle} →</a></div>`,
        );
        entry.marker = new maplibregl.Marker({ element: el })
          .setLngLat(pt.coords)
          .setPopup(popup)
          .addTo(map);
      }

      // Toponym pins — a distinct marker set with multi-name popups, hidden until
      // the reader toggles them on (or a #topo-<id> deep-link requests one).
      for (const topo of toponyms) {
        const el = document.createElement('button');
        el.className = 'am-topo-pin';
        el.setAttribute('aria-label', `${topo.modern} — historical names`);
        const names = topo.historical.length
          ? `<ul class="am-topo-names">${topo.historical.map((n) => `<li>${n}</li>`).join('')}</ul>`
          : '';
        const links = [
          ...topo.maps.map(
            (m) => `<a class="am-pop-link" href="/collection/${m.id}/">${m.title} →</a>`,
          ),
          ...topo.essays.map(
            (e) => `<a class="am-pop-link" href="/essays/${e.slug}/">${e.title} →</a>`,
          ),
        ].join('');
        const pleiades = topo.pleiadesId
          ? `<a class="am-pop-link" href="https://pleiades.stoa.org/places/${topo.pleiadesId}" target="_blank" rel="noopener">Pleiades ↗</a>`
          : '';
        const popup = new maplibregl.Popup({ offset: 12, closeButton: false }).setHTML(
          `<div class="am-pop am-topo-pop"><span class="am-pop-year">Place-names</span>` +
            `<strong class="am-pop-title">${topo.modern}</strong>` +
            names +
            links +
            pleiades +
            `</div>`,
        );
        const marker = new maplibregl.Marker({ element: el })
          .setLngLat(topo.coords)
          .setPopup(popup)
          .addTo(map);
        el.style.display = 'none'; // off until toggled / deep-linked
        topoMarkers.push({ topo, marker });
      }

      map.on('load', () => {
        styleReady = true;
        // Honour any default-on / already-checked layer toggles.
        for (const cb of layerToggles) {
          if (cb.checked && !cb.disabled) {
            const l = geoLayers.find((x) => x.id === cb.dataset.layer);
            if (l) {
              activeLayers.add(l.id);
              addGeoLayer(l);
            }
          }
        }
        syncLayerTime(Number(yearIn.value));
      });
    }

    // Toggle the concordance pin set on/off as one group.
    const setTopoVisible = (on: boolean) => {
      for (const { marker } of topoMarkers) {
        marker.getElement().style.display = on ? '' : 'none';
        if (!on) marker.getPopup()?.remove();
      }
    };
    topoCheck?.addEventListener('change', () => setTopoVisible(topoCheck.checked));

    // Deep-link support: /atlas/#<map-id> flies to and opens that pin (KAN-68);
    // /atlas/#topo-<id> reveals the concordance set and opens that place (KAN-75).
    // In the no-WebGL fallback it scrolls the corresponding list item into view.
    const focusFromHash = () => {
      const raw = decodeURIComponent(location.hash.replace(/^#/, ''));
      if (!raw) return;
      if (raw.startsWith('topo-')) {
        const entry = topoMarkers.find((t) => t.topo.id === raw.slice('topo-'.length));
        if (!entry || !map) return;
        if (topoCheck && !topoCheck.checked) topoCheck.checked = true;
        const open = () => {
          setTopoVisible(true);
          map!.flyTo({ center: entry.topo.coords, zoom: 5 });
          if (!entry.marker.getPopup()?.isOpen()) entry.marker.togglePopup();
        };
        if (styleReady) open();
        else map.once('load', open);
        return;
      }
      const id = raw;
      const entry = markers.find((m) => m.pt.id === id);
      if (!entry) return;
      if (map) {
        const open = () => {
          map!.flyTo({ center: entry.pt.coords, zoom: 4.5 });
          if (entry.marker && !entry.marker.getPopup()?.isOpen()) entry.marker.togglePopup();
        };
        if (styleReady) open();
        else map.once('load', open);
      } else {
        entry.li.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    };
    // Re-run on hash changes; keep a single listener across page-load re-inits.
    const w = window as unknown as { __amHashHandler?: () => void };
    if (w.__amHashHandler) window.removeEventListener('hashchange', w.__amHashHandler);
    w.__amHashHandler = focusFromHash;
    window.addEventListener('hashchange', focusFromHash);
    focusFromHash();

    for (const cb of layerToggles) {
      cb.addEventListener('change', () => {
        const l = geoLayers.find((x) => x.id === cb.dataset.layer);
        if (!l) return;
        if (cb.checked) {
          activeLayers.add(l.id);
          addGeoLayer(l);
          syncLayerTime(Number(yearIn.value));
        } else {
          activeLayers.delete(l.id);
          removeGeoLayer(l.id);
        }
      });
    }

    const apply = () => {
      const q = search.value.trim().toLowerCase();
      const slug = essaySel.value;
      const cutoff = Number(yearIn.value);
      // Footprint filter: keep only pins that fall inside the selected map's ring.
      const footprint = coversSel?.value
        ? coverage.find((c) => c.id === coversSel.value)
        : undefined;
      yearOut.textContent = fmt(cutoff);
      for (const { pt, marker, li } of markers) {
        const matchText =
          !q ||
          pt.title.toLowerCase().includes(q) ||
          pt.region.toLowerCase().includes(q) ||
          pt.essayTitle.toLowerCase().includes(q);
        const matchEssay = !slug || pt.essaySlug === slug;
        const matchYear = pt.year <= cutoff;
        const matchFootprint =
          !footprint || pointInRing(pt.coords[0], pt.coords[1], footprint.ring);
        const show = matchText && matchEssay && matchYear && matchFootprint;
        if (marker) marker.getElement().style.display = show ? '' : 'none';
        li.style.display = show ? '' : 'none';
      }
      syncLayerTime(cutoff);
    };

    search.addEventListener('input', apply);
    essaySel.addEventListener('change', apply);
    coversSel?.addEventListener('change', apply);
    yearIn.addEventListener('input', apply);
    apply();
  }

  const boot = () =>
    document.querySelectorAll<HTMLElement>('[data-atlasmap]').forEach((el) => {
      if (!el.dataset.atlasmapReady) {
        el.dataset.atlasmapReady = '1';
        initAtlasMap(el);
      }
    });
  boot();
  document.addEventListener('astro:page-load', boot);
</script>

