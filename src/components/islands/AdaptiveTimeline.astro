---
/**
 * AdaptiveTimeline (ATLAS-402)
 *
 * Non-linearly compressed timeline for point events, reusing the atlas's
 * square-root compression so ancient centuries don't crush the recent past.
 * Static HTML/CSS — zero client JS. Events with an `href` become focusable
 * links; labels alternate above/below the axis to reduce collisions.
 */
interface Event {
  year: number;
  label: string;
  href?: string;
  accent?: string;
}

interface Props {
  events: Event[];
  from?: number;
  to?: number;
  compress?: boolean;
  ticks?: number[];
  caption?: string;
}

const {
  events,
  from,
  to,
  compress = true,
  ticks,
  caption,
} = Astro.props;

const sorted = [...events].sort((a, b) => a.year - b.year);
const minY = from ?? Math.min(...sorted.map((e) => e.year));
const maxY = to ?? Math.max(...sorted.map((e) => e.year));
const span = Math.max(maxY - minY, 1);

// Square-root compression measured from the most recent point.
const pos = (year: number) => {
  const linear = (year - minY) / span;
  if (!compress) return linear * 100;
  return (1 - Math.sqrt(1 - Math.max(0, Math.min(1, linear)))) * 100;
};

const fmt = (y: number) => (y < 0 ? `${Math.abs(y)} BC` : `AD ${y}`);
const tickYears = ticks ?? [minY, maxY];
---

<figure class="atl">
  <div class="atl-track" role="list">
    <div class="atl-axis" aria-hidden="true">
      {
        tickYears.map((t) => (
          <span class="atl-tick" style={`left:${pos(t)}%`}>
            <span class="atl-tick-label">{fmt(t)}</span>
          </span>
        ))
      }
    </div>
    {
      sorted.map((e, i) => {
        const above = i % 2 === 0;
        const style = `left:${pos(e.year)}%; --accent:${e.accent ?? 'var(--gold)'}`;
        const inner = (
          <>
            <span class="atl-dot" />
            <span class={`atl-label ${above ? 'above' : 'below'}`}>
              <span class="atl-year">{fmt(e.year)}</span>
              <span class="atl-name">{e.label}</span>
            </span>
          </>
        );
        return e.href ? (
          <a class="atl-node" role="listitem" style={style} href={e.href} title={`${e.label} (${fmt(e.year)})`}>
            {inner}
          </a>
        ) : (
          <span class="atl-node" role="listitem" style={style} title={`${e.label} (${fmt(e.year)})`}>
            {inner}
          </span>
        );
      })
    }
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .atl {
    margin: 2rem 0;
  }
  .atl-track {
    position: relative;
    height: 8.5rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    padding: 0 1.5rem;
  }
  .atl-axis {
    position: absolute;
    inset: 0 1.5rem;
    top: 50%;
  }
  .atl-axis::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 1px;
    background: var(--line);
  }
  .atl-tick {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
  }
  .atl-tick-label {
    position: absolute;
    top: 0.4rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    white-space: nowrap;
  }
  .atl-node {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 0;
    display: block;
  }
  .atl-dot {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--accent) 40%, var(--panel-2));
    border: 2px solid var(--accent);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  a.atl-node:hover .atl-dot,
  a.atl-node:focus-visible .atl-dot {
    transform: translate(-50%, -50%) scale(1.4);
  }
  a.atl-node:focus-visible {
    outline: none;
  }
  a.atl-node:focus-visible .atl-dot {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }
  .atl-label {
    position: absolute;
    left: 0;
    transform: translateX(-50%);
    width: max-content;
    max-width: 11rem;
    text-align: center;
    display: grid;
    gap: 0.1rem;
  }
  .atl-label.above {
    bottom: 0.9rem;
  }
  .atl-label.below {
    top: 0.9rem;
  }
  .atl-year {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--accent);
  }
  .atl-name {
    font-family: var(--font-display);
    font-size: var(--step--1);
    color: var(--ink);
    line-height: 1.15;
  }
  a.atl-node .atl-name {
    text-decoration: underline transparent;
    transition: text-decoration-color var(--dur-fast);
  }
  a.atl-node:hover .atl-name {
    text-decoration-color: var(--accent);
  }
  figcaption {
    margin-top: 1rem;
    font-size: var(--step--1);
    color: var(--ink-muted);
    font-style: italic;
  }
</style>
