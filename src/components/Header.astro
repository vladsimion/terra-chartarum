---
const path = Astro.url.pathname;
const nav = [
  { href: '/essays/', label: 'Essays' },
  { href: '/atlas/', label: 'Atlas' },
  { href: '/about/', label: 'About' },
  { href: '/colophon/', label: 'Colophon' },
];
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header" transition:persist>
  <div class="shell header-inner">
    <a href="/" class="brand" aria-label="Terra Chartarum — home">
      <span class="brand-mark" aria-hidden="true">✦</span>
      <span class="brand-name">Terra Chartarum</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--canvas) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.85rem;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: var(--step-1);
    letter-spacing: 0.04em;
  }
  .brand:hover { color: var(--gold); }
  .brand-mark { color: var(--gold); font-size: 0.8em; }
  nav ul {
    display: flex;
    gap: clamp(0.8rem, 2.5vw, 1.75rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    padding-block: 0.25rem;
    border-bottom: 1px solid transparent;
  }
  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--ink);
    border-bottom-color: var(--gold);
  }
  @media (max-width: 640px) {
    .brand-name { display: none; }
  }
</style>
