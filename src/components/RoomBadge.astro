---
// RoomBadge (TC-204 / KAN-99).
//
// A compact room identity chip — glyph + room title — used on essay cards and
// essay headers. Renders as a link to the room page by default, but pass
// `href={null}` to render a plain <span> when the badge sits inside another
// anchor (e.g. an EssayCard whose whole body is a link), to avoid nested links.
import { getRoom, type RoomSlug } from '../data/rooms';

interface Props {
  room: RoomSlug;
  /** Link target; defaults to the room page. Pass null to render a non-link span. */
  href?: string | null;
  /** Visual weight: 'ghost' (outline) or 'solid' (filled). */
  variant?: 'ghost' | 'solid';
}

const { room: slug, href, variant = 'ghost' } = Astro.props;
const room = getRoom(slug);
const target = href === undefined ? `/rooms/${slug}/` : href;
const label = room ? room.title : slug;
const glyph = room?.glyph;
---

{
  target ? (
    <a class:list={['room-badge', variant]} href={target} aria-label={`Room: ${label}`}>
      {glyph && <img src={glyph} alt="" width="16" height="16" aria-hidden="true" />}
      <span>{label}</span>
    </a>
  ) : (
    <span class:list={['room-badge', variant]}>
      {glyph && <img src={glyph} alt="" width="16" height="16" aria-hidden="true" />}
      <span>{label}</span>
    </span>
  )
}

<style>
  .room-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
    text-decoration: none;
    white-space: nowrap;
    line-height: 1;
  }
  a.room-badge:hover {
    color: var(--gold);
    border-color: color-mix(in srgb, var(--gold) 45%, var(--line));
  }
  .room-badge.solid {
    color: var(--gold);
    background: color-mix(in srgb, var(--gold) 10%, transparent);
    border-color: color-mix(in srgb, var(--gold) 35%, var(--line));
  }
  .room-badge img {
    display: block;
  }
</style>
